# ============================================================
# NexCRM Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ============================================================

# ── Application ─────────────────────────────────────────────
NODE_ENV=development
APP_NAME=NexCRM
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://nexcrm:nexcrm_secret@localhost:5432/nexcrm_dev?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
# Separate DBs per concern
REDIS_SESSION_DB=1
REDIS_CACHE_DB=2
REDIS_QUEUE_DB=3

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_URL=amqp://nexcrm:rabbitmq_secret@localhost:5672
RABBITMQ_VHOST=nexcrm
RABBITMQ_PREFETCH_COUNT=10

# ── JWT Authentication ────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_at_least_64_chars_long_for_security
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_at_least_64_chars_long_for_security
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Cookie ───────────────────────────────────────────────────
COOKIE_SECRET=CHANGE_ME_cookie_secret_at_least_32_chars
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false        # true in production (HTTPS only)
COOKIE_SAME_SITE=lax       # strict in production

# ── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM_NAME=NexCRM
SMTP_FROM_EMAIL=noreply@nexcrm.io

# ── Storage (S3 Compatible) ──────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=nexcrm-uploads
S3_PUBLIC_URL=http://localhost:9000/nexcrm-uploads

# ── AI Integration ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o-mini
AI_MAX_TOKENS=2048
AI_RATE_LIMIT_RPM=60

# ── WhatsApp / Messaging ─────────────────────────────────────
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
TELEGRAM_BOT_TOKEN=

# ── Stripe (Payments) ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Observability ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=nexcrm
OTEL_SERVICE_VERSION=1.0.0
LOG_LEVEL=debug    # error | warn | info | debug
LOG_FORMAT=pretty  # pretty | json

# ── Service Ports ────────────────────────────────────────────
WEB_PORT=3000
API_GATEWAY_PORT=4000
AUTH_SERVICE_PORT=4001
CRM_SERVICE_PORT=4002
FINANCE_SERVICE_PORT=4003
NOTIFICATION_SERVICE_PORT=4004
AI_SERVICE_PORT=4005
WORKFLOW_SERVICE_PORT=4006

# ── Internal Service URLs ────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:4001
CRM_SERVICE_URL=http://localhost:4002
FINANCE_SERVICE_URL=http://localhost:4003
NOTIFICATION_SERVICE_URL=http://localhost:4004
AI_SERVICE_URL=http://localhost:4005
WORKFLOW_SERVICE_URL=http://localhost:4006

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_TTL=60         # seconds
RATE_LIMIT_MAX=100        # requests per TTL per IP
RATE_LIMIT_AUTH_MAX=10    # stricter for auth endpoints

# ── Monitoring ───────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_password

# ── pgAdmin ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@nexcrm.io
PGADMIN_PASSWORD=CHANGE_ME_pgadmin_password
PGADMIN_PORT=5050

# ── Encryption ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_32_byte_hex_key_for_field_encryption
BCRYPT_ROUNDS=12
