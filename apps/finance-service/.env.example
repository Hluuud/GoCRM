# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3003
SERVICE_NAME=finance-service

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nexcrm:nexcrm_password@localhost:5432/nexcrm_db?schema=public

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_256_bit_random_secret

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://nexcrm:nexcrm_password@localhost:5672
RABBITMQ_EXCHANGE=nexcrm.events

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
LOG_LEVEL=debug
