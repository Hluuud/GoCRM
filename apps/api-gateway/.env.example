# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SERVICE_NAME=api-gateway

# ─── JWT (must match auth-service secret) ─────────────────────────────────────
JWT_SECRET=change_me_to_a_256_bit_random_secret

# ─── Downstream Services ──────────────────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
CRM_SERVICE_URL=http://localhost:3002
FINANCE_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004
AI_SERVICE_URL=http://localhost:3005
WORKFLOW_SERVICE_URL=http://localhost:3006

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=200

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://app.nexcrm.com

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
LOG_LEVEL=debug
