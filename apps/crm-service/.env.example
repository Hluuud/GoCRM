# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
SERVICE_NAME=crm-service

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://nexcrm:nexcrm_password@localhost:5432/nexcrm_db?schema=public

# ─── JWT (for validating tokens issued by auth-service) ───────────────────────
JWT_SECRET=change_me_to_a_256_bit_random_secret

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://nexcrm:nexcrm_password@localhost:5672
RABBITMQ_EXCHANGE=nexcrm.events
RABBITMQ_QUEUE_CRM=crm.events

# ─── Redis (caching & distributed locking) ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
LOG_LEVEL=debug
