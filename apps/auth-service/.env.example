# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
SERVICE_NAME=auth-service

# ─── Database (PostgreSQL via Prisma) ─────────────────────────────────────────
DATABASE_URL=postgresql://nexcrm:nexcrm_password@localhost:5432/nexcrm_db?schema=public

# ─── Redis (session store & refresh token store) ──────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_256_bit_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_another_256_bit_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ─── Password Hashing ─────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Rate Limiting ────────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=20

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ─── Frontend (CORS) ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
LOG_LEVEL=debug
