# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3004
SERVICE_NAME=notification-service

# ─── RabbitMQ (event consumer) ────────────────────────────────────────────────
RABBITMQ_URL=amqp://nexcrm:nexcrm_password@localhost:5672
RABBITMQ_EXCHANGE=nexcrm.events
RABBITMQ_QUEUE_NOTIFICATIONS=notification.events
RABBITMQ_DEAD_LETTER_QUEUE=notification.events.dlq

# ─── Email (SMTP via Nodemailer) ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@nexcrm.com
SMTP_PASS=your_app_password_here
EMAIL_FROM="NexCRM <no-reply@nexcrm.com>"

# ─── Webhooks ─────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=change_me_to_random_secret

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
LOG_LEVEL=debug
